{
  "name": "assistant-stream",
  "version": "0.2.46",
  "description": "Streaming utilities for AI assistants",
  "keywords": [
    "ai",
    "streaming",
    "assistant",
    "chat",
    "openai",
    "llm",
    "assistant-ui",
    "resumable"
  ],
  "author": "AgentbaseAI Inc.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "aui-source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./utils": {
      "aui-source": "./src/utils.ts",
      "types": "./dist/utils.d.ts",
      "default": "./dist/utils.js"
    },
    "./resumable": {
      "aui-source": "./src/resumable/index.ts",
      "types": "./dist/resumable/index.d.ts",
      "default": "./dist/resumable/index.js"
    },
    "./resumable/redis": {
      "aui-source": "./src/resumable/redis.ts",
      "types": "./dist/resumable/redis.d.ts",
      "default": "./dist/resumable/redis.js"
    },
    "./resumable/ioredis": {
      "aui-source": "./src/resumable/ioredis.ts",
      "types": "./dist/resumable/ioredis.d.ts",
      "default": "./dist/resumable/ioredis.js"
    },
    "./resumable/upstash": {
      "aui-source": "./src/resumable/upstash.ts",
      "types": "./dist/resumable/upstash.d.ts",
      "default": "./dist/resumable/upstash.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "utils",
    "resumable",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "aui-build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "nanoid": "5.1.6",
    "secure-json-parse": "^4.1.0"
  },
  "peerDependencies": {
    "redis": "^5.0.0",
    "ioredis": "^5.0.0",
    "@upstash/redis": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "redis": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "@upstash/redis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@assistant-ui/x-buildutils": "workspace:*",
    "@types/json-schema": "^7.0.15",
    "vitest": "^4.0.16"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "homepage": "https://www.assistant-ui.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/assistant-ui/assistant-ui.git",
    "directory": "packages/assistant-stream"
  },
  "bugs": {
    "url": "https://github.com/assistant-ui/assistant-ui/issues"
  }
}
